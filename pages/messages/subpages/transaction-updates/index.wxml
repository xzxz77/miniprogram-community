<view class="container bg-gray-50 min-h-screen p-4">
  <block wx:if="{{isLoading}}">
    <view class="text-center text-gray-400 py-10 flex flex-col items-center">加载中...</view>
  </block>
  <block wx:elif="{{updates.length === 0}}">
    <view class="text-center text-gray-400 py-10 flex flex-col items-center">
      <image src="/assets/icons/message.png" class="w-24 h-24 mb-2 opacity-20"></image>
      <text>暂无交易动态</text>
    </view>
  </block>
  <block wx:else>
    <block wx:for="{{updates}}" wx:key="id">
      <view class="bg-white p-4 rounded-xl mb-3 shadow-sm flex" bindtap="onItemTap" data-id="{{item.orderId}}">
        <view class="icon-wrap mr-3 {{item.status === 'pay' ? 'bg-orange-100' : (item.status === 'deliver' ? 'bg-blue-100' : 'bg-green-100')}}">
          <image class="status-icon" src="{{item.status === 'pay' ? '/assets/icons/pay.png' : (item.status === 'deliver' ? '/assets/icons/deliver.png' : '/assets/icons/pay.png')}}" mode="aspectFit"></image>
        </view>
        <view class="flex-1">
          <view class="flex justify-between items-center mb-1">
            <text class="font-bold text-gray-800 text-base">{{item.title}}</text>
            <text class="text-xs text-gray-400">{{item.time}}</text>
          </view>
          <view class="text-gray-600 text-sm mb-2 line-clamp-2">
            {{item.content}}
          </view>
          <view class="bg-gray-50 p-2 rounded flex items-center">
            <image wx:if="{{item.image}}" class="goods-thumb mr-2" src="{{item.image}}" mode="aspectFill"></image>
            <view wx:else class="goods-thumb mr-2 bg-gray-200"></view>
            <text class="text-xs text-gray-500">点击查看详情</text>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>