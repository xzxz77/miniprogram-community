/* pages/messages/subpages/transaction-updates/index.wxss */
.min-h-screen { min-height: 100vh; }
.p-4 { padding: 32rpx; }
.p-2 { padding: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mr-3 { margin-right: 24rpx; }
.mr-2 { margin-right: 16rpx; }

.icon-wrap {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bg-blue-100 { background-color: #dbeafe; }
.bg-orange-100 { background-color: #ffedd5; }
.bg-green-100 { background-color: #dcfce7; }

.status-icon { width: 40rpx; height: 40rpx; }
.goods-thumb { width: 60rpx; height: 60rpx; border-radius: 8rpx; background-color: #e5e7eb; }

/* Tailwind-like utilities if not in app.wxss */
.w-24 { width: 192rpx; }
.h-24 { height: 192rpx; }
.opacity-20 { opacity: 0.2; }
.flex-col { flex-direction: column; }
.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}