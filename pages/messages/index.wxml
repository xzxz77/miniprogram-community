<!-- pages/messages/index.wxml -->
<view class="container bg-white h-100">
  <view class="header px-4 py-3 sticky top-0 bg-white z-10 border-b border-gray-50 flex justify-between items-center">
    <view class="text-xl font-bold text-gray-800">消息</view>
    <view class="text-sm text-gray-500">清除未读</view>
  </view>

  <view class="flex justify-around py-4 border-b border-gray-100">
    <navigator class="flex-col items-center">
      <view class="icon-circle bg-orange-100 text-orange-500 relative">
        <text class="iconfont icon-bell text-xl"></text>
        <view class="dot bg-red-500"></view>
      </view>
      <text class="text-xs text-gray-600 mt-1">服务通知</text>
    </navigator>
    <navigator class="flex-col items-center">
      <view class="icon-circle bg-blue-100 text-blue-500">
        <text class="iconfont icon-comment text-xl"></text>
      </view>
      <text class="text-xs text-gray-600 mt-1">互动消息</text>
    </navigator>
    <navigator class="flex-col items-center">
      <view class="icon-circle bg-green-100 text-green-500">
        <text class="iconfont icon-shop text-xl"></text>
      </view>
      <text class="text-xs text-gray-600 mt-1">交易动态</text>
    </navigator>
  </view>

  <view class="chat-list">
    <navigator url="/pages/messages/subpages/chat-detail/index?id=1" class="chat-item flex items-center px-4 py-4 hover-bg-gray-50">
      <view class="avatar-wrap relative mr-3">
        <image class="avatar" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=100&h=100"></image>
        <view class="badge-num">2</view>
      </view>
      <view class="flex-1 border-b border-gray-50 pb-4 h-full">
        <view class="flex justify-between items-baseline mb-1">
          <text class="font-bold text-gray-800">李大爷</text>
          <text class="text-xs text-gray-400">10:23</text>
        </view>
        <view class="flex justify-between items-center">
          <text class="text-sm text-gray-500 truncate w-48">小伙子，那个手表还在吗？诚心想要。</text>
          <image class="thumb" src="https://images.unsplash.com/photo-1546868871-7041f2a55e12?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" mode="aspectFill"></image>
        </view>
      </view>
    </navigator>
  </view>
</view>
