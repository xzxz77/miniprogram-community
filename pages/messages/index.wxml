<!-- pages/messages/index.wxml -->
<view class="page-container">
  <!-- Custom Header -->
  <view class="custom-header">
    <view class="header-content">
      <text class="page-title">消息</text>
      <view class="clear-btn" bindtap="onClearUnread">
        <text>清除未读</text>
      </view>
    </view>
  </view>

  <!-- Navigation Grid -->
  <view class="nav-grid">
    <navigator url="/pages/messages/subpages/service-notifications/index" hover-class="none" class="nav-item" bindtap="onServiceTap">
      <view class="icon-wrapper bg-orange">
        <image class="nav-icon" src="/assets/icons/message-active.png"></image>
        <view class="badge-dot" wx:if="{{serviceUnread > 0}}"></view>
      </view>
      <text class="nav-label">服务通知</text>
    </navigator>
    
    <navigator url="/pages/messages/subpages/interaction-messages/index" hover-class="none" class="nav-item">
      <view class="icon-wrapper bg-blue">
        <image class="nav-icon" src="/assets/icons/comment.png"></image>
        <view class="badge-dot" wx:if="{{interactionUnread > 0}}"></view>
      </view>
      <text class="nav-label">互动消息</text>
    </navigator>
    
    <navigator url="/pages/messages/subpages/transaction-updates/index" hover-class="none" class="nav-item" bindtap="onTransactionTap">
      <view class="icon-wrapper bg-green">
        <image class="nav-icon" src="/assets/icons/pay.png"></image>
        <view class="badge-dot" wx:if="{{transactionUnread > 0}}"></view>
      </view>
      <text class="nav-label">交易动态</text>
    </navigator>
  </view>

  <!-- Chat List -->
  <view class="chat-list">
    <block wx:for="{{chatList}}" wx:key="id">
      <navigator url="/pages/messages/subpages/chat-detail/index?id={{item.id}}" class="chat-item" hover-class="chat-item-hover">
        <view class="avatar-container">
          <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="badge-count" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
        </view>
        
        <view class="content-container">
          <view class="row-top">
            <text class="username">{{item.name}}</text>
            <text class="time">{{item.time}}</text>
          </view>
          
          <view class="row-bottom">
            <text class="message-preview">{{item.message}}</text>
            <image class="goods-thumb" src="{{item.goodsImg}}" mode="aspectFill" wx:if="{{item.goodsImg}}"></image>
          </view>
        </view>
      </navigator>
    </block>
  </view>
</view>
