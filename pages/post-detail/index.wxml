<!-- pages/post-detail/index.wxml -->
<view class="container bg-white min-h-screen pb-safe">
  <block wx:if="{{isLoading}}">
    <view class="flex items-center justify-center py-20">
      <view class="loading-spinner"></view>
    </view>
  </block>
  <block wx:elif="{{post}}">
    <!-- Author Info -->
    <view class="p-4 flex justify-between items-center">
      <view class="flex items-center" bindtap="onAuthorTap">
        <image class="avatar bg-gray-100" src="{{post.author.avatarUrl}}" mode="aspectFill"></image>
        <view class="ml-3">
          <view class="font-bold text-gray-900 text-base">{{post.author.nickName}}</view>
          <view class="text-xs text-gray-400 mt-0.5">
            {{post.timeAgo}} · {{post.author.community}}
          </view>
        </view>
      </view>
      <!-- Follow button placeholder if needed -->
    </view>

    <!-- Content -->
    <view class="px-4 pb-4">
      <view class="text-lg text-gray-800 leading-relaxed mb-4">
        <text wx:if="{{post.category && post.category !== '全部'}}" class="text-blue-600 font-bold mr-1">#{{post.category}}#</text>
        {{post.content}}
      </view>
      
      <!-- Images -->
      <view class="grid-3 gap-2 mt-2" wx:if="{{post.images.length > 0}}">
        <block wx:for="{{post.images}}" wx:key="*this">
          <view class="relative" style="padding-bottom: 100%; height: 0;">
            <image src="{{item}}" mode="aspectFill" class="absolute top-0 left-0 w-full h-full rounded-lg bg-gray-100" bindtap="previewImage" data-current="{{item}}" data-urls="{{post.images}}"></image>
          </view>
        </block>
      </view>
    </view>

    <!-- Stats -->
    <view class="px-4 py-3 flex items-center justify-between text-gray-400 text-sm border-b border-gray-100">
      <view>浏览 {{post.viewCount || 0}}</view>
      <view class="flex items-center space-x-4">
        <view class="flex items-center ">点赞<text class="iconfont icon-thumb-up mr-1 text-xs"></text>{{post.likeCount}}</view>
      </view>
    </view>

    <!-- Comments Section -->
    <view class="p-4" id="comments">
      <view class="font-bold text-base mb-4">全部评论 ({{comments.length}})</view>
      <block wx:if="{{comments.length > 0}}">
        <block wx:for="{{comments}}" wx:key="_id">
          <view class="flex items-start mb-4" bindtap="onReply" data-id="{{item._id}}" data-name="{{item.user.nickName}}">
            <image class="w-8 h-8 rounded-full bg-gray-100 mr-2" src="{{item.user.avatarUrl}}"></image>
            <view class="flex-1">
              <view class="flex justify-between items-baseline mb-1">
                <text class="text-sm font-bold text-gray-600">{{item.user.nickName}}</text>
                <text class="text-xs text-gray-400">{{item.timeAgo}}</text>
              </view>
              <view class="text-base text-gray-800">{{item.content}}</view>
            </view>
          </view>
        </block>
      </block>
      <view wx:else class="text-center text-gray-400 py-10 text-sm">
        <view>暂无评论，快来抢沙发~</view>
      </view>
    </view>

    <!-- Bottom Bar -->
    <view class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 px-4 py-2 flex items-center justify-between pb-safe z-10 shadow-lg">
      <view class="bg-gray-100 rounded-full flex-1 px-4 py-2 text-gray-400 text-sm flex items-center" bindtap="onShowInput">
        <text class="iconfont icon-edit mr-2 text-gray-400"></text>
        {{placeholder || '说点什么...'}}
      </view>
      <view class="flex items-center ml-4 space-x-6">
        <view class="flex flex-col items-center" bindtap="onLikeTap">
          <image class="action-icon" src="/assets/icons/{{post.isLiked ? 'start-active' : 'start'}}.png" mode="aspectFit"></image>
          <text class="text-xs {{post.isLiked ? 'text-orange-500' : 'text-gray-500'}} mt-0.5">{{post.likeCount > 0 ? post.likeCount : '点赞'}}</text>
        </view>
        <view class="flex flex-col items-center" bindtap="onFavoriteTap">
          <image class="action-icon" src="/assets/icons/{{post.isFavorited ? 'heart' : 'heart-active'}}.png" mode="aspectFit"></image>
          <text class="text-xs {{post.isFavorited ? 'text-orange-500' : 'text-gray-500'}} mt-0.5">收藏</text>
        </view>
      </view>
    </view>
    
    <!-- Input Layer -->
    <view class="mask" wx:if="{{showInput}}" bindtap="hideInput"></view>
    <view class="comment-input-layer" wx:if="{{showInput}}" style="bottom: {{keyboardHeight}}px;">
      <view class="flex items-end">
        <textarea class="comment-input" 
          placeholder="{{placeholder}}" 
          focus="{{showInput}}"
          value="{{content}}"
          adjust-position="{{false}}"
          show-confirm-bar="{{false}}"
          cursor-spacing="20"
          auto-height
          fixed
          disable-default-padding
          bindinput="onInput"
          bindfocus="onFocus"
          bindblur="onBlur"
          bindconfirm="onSend"
        />
        <button class="send-btn" bindtap="onSend" >发送</button>
      </view>
    </view>
    
    <!-- Spacer for bottom bar -->
    <view class="h-20"></view>
  </block>
</view>