/* pages/refund-apply/index.wxss */
.container {
  background-color: #f9fafb;
  min-height: 100vh;
}

.bg-white { background-color: #ffffff; }
.bg-gray-50 { background-color: #f9fafb; }
.bg-black-50 { background-color: rgba(0, 0, 0, 0.5); }
.bg-orange-500 { background-color: #f97316; }

.text-white { color: #ffffff; }
.text-gray-800 { color: #1f2937; }
.text-gray-900 { color: #111827; }
.text-gray-400 { color: #9ca3af; }
.text-gray-300 { color: #d1d5db; }
.text-red-500 { color: #ef4444; }

.font-bold { font-weight: 700; }
.text-lg { font-size: 36rpx; }
.text-sm { font-size: 28rpx; }
.text-xs { font-size: 24rpx; }
.text-2xl { font-size: 48rpx; }

.rounded-lg { border-radius: 16rpx; }
.rounded-full { border-radius: 9999px; }
.rounded-bl { border-bottom-left-radius: 8rpx; }
.rounded { border-radius: 8rpx; }

.shadow-sm { box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05); }
.shadow-lg { box-shadow: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -2rpx rgba(0, 0, 0, 0.05); }

.flex { display: flex; }
.flex-wrap { flex-wrap: wrap; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.items-center { align-items: center; }

.w-full { width: 100%; }
.h-32 { height: 256rpx; }
.w-20 { width: 160rpx; }
.h-20 { height: 160rpx; }
.w-5 { width: 40rpx; }
.h-5 { height: 40rpx; }
.h-full { height: 100%; }

.p-4 { padding: 32rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-6 { margin-bottom: 48rpx; }
.mt-2 { margin-top: 16rpx; }

.border { border-width: 1rpx; }
.border-dashed { border-style: dashed; }
.border-gray-300 { border-color: #d1d5db; }

.relative { position: relative; }
.absolute { position: absolute; }
.top-0 { top: 0; }
.right-0 { right: 0; }
.overflow-hidden { overflow: hidden; }
.text-right { text-align: right; }

.gap-3 { gap: 24rpx; }
