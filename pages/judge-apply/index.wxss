/* pages/judge-apply/index.wxss */
.container {
  padding: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #1f2937;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.input, .textarea {
  width: 100%;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  height: 200rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(239, 68, 68, 0.8);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 8rpx;
  font-size: 24rpx;
}

.add-btn {
  width: 160rpx;
  height: 160rpx;
  background-color: #f3f4f6;
  border: 2rpx dashed #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #9ca3af;
}

.submit-btn {
  background-color: #2563eb;
  color: white;
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-weight: 600;
  font-size: 32rpx;
  margin-top: 48rpx;
}
