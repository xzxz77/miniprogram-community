<!-- pages/goods-detail/index.wxml -->
<view class="container bg-gray-50 pb-24" wx:if="{{!isLoading}}">
  <!-- Navbar -->
  <view class="nav-bar fixed top-0 w-full z-20 flex items-center px-4" style="padding-top: {{statusBarHeight}}px; height: 44px;">
    <!-- Back Button only, removed Share button -->
    <view class="nav-btn bg-black-20 rounded-full w-8 h-8 flex items-center justify-center text-white" bindtap="goBack">
      <image src="/assets/icons/back.png" class="cat-img"></image>
    </view>
  </view>

  <!-- Swiper -->
  <view class="relative">
    <swiper class="swiper" indicator-dots="{{false}}" autoplay="{{false}}" bindchange="onSwiperChange" style="height: 750rpx;">
      <swiper-item wx:for="{{good.images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="w-full h-full" bindtap="previewImage" data-url="{{item}}"></image>
      </swiper-item>
    </swiper>
    
    <!-- Sold Overlay -->
    <view wx:if="{{good.status === 'sold'}}" class="absolute top-0 left-0 w-full h-full flex items-center justify-center z-10" style="background: rgba(0,0,0,0.3); pointer-events: none;">
        <view class="bg-black text-white text-2xl font-bold px-8 py-3 rounded-full border-4 border-white transform -rotate-12 opacity-80">已卖出</view>
    </view>
    <view wx:if="{{good.status === 'offline'}}" class="absolute top-0 left-0 w-full h-full flex items-center justify-center z-10" style="background: rgba(0,0,0,0.3); pointer-events: none;">
        <view class="bg-gray-600 text-white text-2xl font-bold px-8 py-3 rounded-full border-4 border-white transform -rotate-12 opacity-80">已下架</view>
    </view>

    <!-- Image Indicator -->
    <view class="absolute bottom-4 right-4 bg-black-50 text-white text-xs px-3 py-1 rounded-full">
      {{currentImage + 1}}/{{good.images.length}}
    </view>
  </view>

  <!-- Info -->
  <view class="bg-white p-4 mb-3 rounded-b-xl shadow-sm -mt-4 relative z-10">
    <view class="flex items-baseline mb-2 justify-between">
      <view class="flex items-baseline">
        <text class="text-red-500 font-bold text-3xl mr-1 font-din">¥{{good.price}}</text>
        <view class="bg-orange-100 text-orange-600 text-xs px-2 py-1 rounded font-bold ml-2">{{good.deliveryMethod}}</view>
      </view>
      <view class="flex text-gray-400 text-xs items-center">
         <text class="iconfont icon-eye mr-1"></text>
         <text>{{good.views || 0}}浏览</text>
      </view>
    </view>
    
    <view class="font-bold text-lg text-gray-900 leading-snug mb-3">{{good.title}}</view>
    
    <view class="flex items-center text-xs text-gray-400 justify-between">
      <view class="flex items-center">
        <text class="iconfont icon-location mr-1"></text>
        <text>{{good.location}}</text>
      </view>
      <view class="flex items-center">
        <text class="iconfont icon-clock mr-1"></text>
        <text>发布于 {{good.publishTime}}</text>
      </view>
    </view>
  </view>

  <!-- Seller -->
  <view class="bg-white p-4 mb-3 flex items-center justify-between mx-3 rounded-xl shadow-sm" bindtap="onViewSeller">
    <view class="flex items-center">
      <image src="{{seller.avatarUrl}}" class="avatar w-10 h-10 rounded-full bg-gray-100"></image>
      <view class="ml-3">
        <view class="font-bold text-gray-800 text-sm">{{seller.nickName}}</view>
        <view class="flex items-center mt-1">
          <view wx:if="{{seller.isVerified}}" class="bg-blue-50 text-blue-600 text-xs px-1 rounded mr-1 flex items-center">
             <text class="iconfont icon-check-circle text-xs mr-1"></text>已认证
          </view>
          <view class="text-xs text-gray-500">{{seller.credit}}</view>
        </view>
      </view>
    </view>
    <view class="flex items-center text-gray-400">
      <text class="text-xs mr-1">查看主页</text>
      <text class="iconfont icon-arrow-right text-xs"></text>
    </view>
  </view>

  <!-- Content -->
  <view class="bg-white p-4 mb-3 mx-3 rounded-xl shadow-sm">
    <view class="font-bold text-sm mb-3 text-gray-900">宝贝详情</view>
    <view class="text-base text-gray-800 leading-relaxed mb-4 whitespace-pre-wrap">{{good.description}}</view>

    <view class="flex text-xs text-gray-500 space-x-4 bg-gray-50 p-3 rounded-lg">
      <text class="mr-4">分类: {{good.category}}</text>
    </view>
    
    <!-- Comments Section -->
    <view class="h-px bg-gray-50 w-full mb-3"></view>
    
    <view class="mb-3">
      <view class="font-bold text-sm mb-3 text-gray-900 flex justify-between items-center">
        <text>留言 ({{comments.length}})</text>
        <view class="text-xs text-blue-500" bindtap="onShowInput">写留言</view>
      </view>
      
      <block wx:if="{{comments.length > 0}}">
        <view class="comment-item mb-3" wx:for="{{comments}}" wx:key="_id">
          <view class="flex items-start">
            <image src="{{item.user.avatarUrl || '/assets/icons/profile.png'}}" class="w-8 h-8 rounded-full bg-gray-100 mr-2"></image>
            <view class="flex-1">
              <view class="flex justify-between items-center mb-1">
                <text class="text-xs font-bold text-gray-700">{{item.user.nickName || '用户'}}</text>
                <text class="text-xs text-gray-400">{{item.timeDisplay}}</text>
              </view>
              <view class="text-sm text-gray-600">{{item.content}}</view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="text-center text-gray-400 text-xs py-4">暂无留言，快来问问细节吧</view>
    </view>

    <view class="h-px bg-gray-50 w-full mb-3"></view>
    
  </view>
  
  <!-- Safety Tip -->
  <view class="p-4 text-center">
     <text class="text-xs text-gray-400">如遇诈骗等违规行为，请点击右上角举报</text>
  </view>

  <!-- Bottom Bar -->
  <view class="bottom-bar-wrapper" wx:if="{{!showCommentInput}}">
    <!-- Buyer Bottom Bar -->
    <view class="bottom-bar pb-safe" wx:if="{{!isOwner}}">
      <!-- Left: Icons -->
      <view class="action-icons">
        <view class="icon-item" bindtap="toggleFavorite">
          <image src="/assets/icons/{{isFavorited ? 'heart.png' : 'heart-active.png'}}" class="icon-img" mode="aspectFit"></image>
          <text class="icon-text">收藏</text>
        </view>
        <view class="icon-item" bindtap="onShowInput">
          <image src="/assets/icons/comment.png" class="icon-img" mode="aspectFit"></image>
          <text class="icon-text">留言</text>
        </view>
      </view>

      <!-- Right: Action Buttons -->
      <view class="action-buttons">
        <view class="trade-btn chat-btn" bindtap="onContactSeller">
          <text>聊一聊</text>
        </view>
        
        <block wx:if="{{good.status === 'sold'}}">
           <view class="trade-btn buy-btn" style="background-color: #9ca3af;">
              <text>已卖出</text>
           </view>
        </block>
        <block wx:elif="{{good.status === 'offline'}}">
           <view class="trade-btn buy-btn" style="background-color: #9ca3af;">
              <text>已下架</text>
           </view>
        </block>
        <block wx:else>
           <view class="trade-btn buy-btn" bindtap="onBuyNow">
             <text>我想要</text>
           </view>
        </block>
      </view>
    </view>

    <!-- Seller Bottom Bar -->
    <view class="bottom-bar pb-safe" wx:else>
      <view class="action-buttons full-width" style="display: flex; gap: 20rpx; width: 100%;">
        <view class="trade-btn edit-btn bg-blue-500" bindtap="onEditGood" style="flex: 1; background-color: #3b82f6;">
          <text>编辑</text>
        </view>
        <view class="trade-btn off-btn bg-gray-500" bindtap="onOffShelf" style="flex: 1; background-color: #6b7280;">
          <text>下架</text>
        </view>
        <view class="trade-btn delete-btn bg-red-500" bindtap="onDeleteGood" style="flex: 1; background-color: #ef4444;">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>
</view>

<view wx:else class="flex items-center justify-center h-screen bg-white">
  <view class="loading-spinner"></view>
</view>

<!-- Comment Input Layer -->
<view class="mask" wx:if="{{showCommentInput}}" bindtap="hideInput"></view>
<view class="comment-input-layer" wx:if="{{showCommentInput}}" style="bottom: {{keyboardHeight}}px">
  <input class="comment-input" 
    placeholder="想问什么？" 
    focus="{{showCommentInput}}"
    value="{{commentContent}}"
    adjust-position="{{false}}"
    bindinput="onCommentInput"
    bindfocus="onInputFocus"
    bindblur="onInputBlur"
    confirm-type="send"
    bindconfirm="onSendComment"
  />
  <view class="comment-send-btn {{!commentContent ? 'disabled' : ''}}" bindtap="onSendComment">发送</view>
</view>
