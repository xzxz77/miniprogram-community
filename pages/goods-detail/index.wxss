/* pages/goods-detail/index.wxss */
page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  min-height: 100vh;
}

/* Utilities */
.bg-gray-50 { background-color: #f9fafb; }
.bg-white { background-color: #ffffff; }
.bg-white-70 { background-color: rgba(255,255,255,0.9); backdrop-filter: blur(4px); border: 1rpx solid rgba(0,0,0,0.05); }
.bg-black-20 { background-color: rgba(0,0,0,0.2); backdrop-filter: blur(4px); }
.bg-black-50 { background-color: rgba(0,0,0,0.5); backdrop-filter: blur(4px); }
.bg-orange-100 { background-color: #e6f7ff; }
.bg-blue-50 { background-color: #e6f7ff; }

.text-white { color: #ffffff; }
.text-gray-900 { color: #111827; }
.text-gray-800 { color: #1f2937; }
.text-gray-700 { color: #374151; }
.text-gray-500 { color: #6b7280; }
.text-gray-400 { color: #9ca3af; }
.text-red-500 { color: #ef4444; }
.text-orange-600 { color: #ea580c; }
.text-blue-600 { color: #2563eb; }

.font-bold { font-weight: 700; }
.font-din { font-family: 'DIN Alternate', 'Roboto', sans-serif; }
.text-xs { font-size: 24rpx; }
.text-sm { font-size: 28rpx; }
.text-base { font-size: 32rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 40rpx; }
.text-2xl { font-size: 48rpx; }
.text-3xl { font-size: 56rpx; }

.leading-snug { line-height: 1.4; }
.leading-relaxed { line-height: 1.6; }

.rounded { border-radius: 8rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded-b-xl { border-bottom-left-radius: 24rpx; border-bottom-right-radius: 24rpx; }
.rounded-full { border-radius: 9999px; }

.shadow-sm { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }

.w-full { width: 100%; }
.h-full { height: 100%; }
.w-8 { width: 64rpx; }
.h-8 { height: 64rpx; }
.w-10 { width: 80rpx; }
.h-10 { height: 80rpx; }
.h-px { height: 1rpx; }
.h-screen { height: 100vh; }

.p-4 { padding: 32rpx; }
.px-1 { padding-left: 8rpx; padding-right: 8rpx; }
.px-2 { padding-left: 16rpx; padding-right: 16rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-1 { padding-top: 8rpx; padding-bottom: 8rpx; }
.pb-24 { padding-bottom: 180rpx; }
.pb-safe { padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx); }

.mx-3 { margin-left: 24rpx; margin-right: 24rpx; }
.mt-1 { margin-top: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mr-1 { margin-right: 8rpx; }
.ml-2 { margin-left: 16rpx; }
.ml-3 { margin-left: 24rpx; }
.-mt-4 { margin-top: -32rpx; }

.flex { display: flex; }
.items-center { align-items: center; }
.items-baseline { align-items: baseline; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.space-x-4 > text + text { margin-left: 32rpx; }

.fixed { position: fixed; }
.absolute { position: absolute; }
.relative { position: relative; }
.top-0 { top: 0; }
.bottom-4 { bottom: 32rpx; }
.right-4 { right: 32rpx; }
.z-10 { z-index: 10; }
.z-20 { z-index: 20; }

.whitespace-pre-wrap { white-space: pre-wrap; }

/* Navbar */
/* .nav-bar { */
  /* height set inline */
/* } */

/* Bottom Bar */
.bottom-bar-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}

.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  box-sizing: content-box; /* Important for pb-safe */
}

/* Icons Group */
.action-icons {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 40rpx;
  background: transparent;
  padding: 0;
  line-height: 1;
}

.icon-item:last-child {
  margin-right: 0;
}

.icon-item::after {
  border: none;
}

.icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
}

.icon-text {
  font-size: 20rpx;
  color: #666;
}

/* Buttons Group */
.action-buttons {
  flex: 1;
  display: flex;
  height: 80rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.2);
}

.trade-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  transition: opacity 0.2s;
}

.trade-btn:active {
  opacity: 0.9;
}

.chat-btn {
  background: linear-gradient(90deg, #ffc107, #ffb300);
  color: #333; /* Dark text for yellow bg */
}

.buy-btn {
  background: linear-gradient(90deg, #ff6b00, #ff4d4f);
}

/* Loading */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #ff6b00;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
