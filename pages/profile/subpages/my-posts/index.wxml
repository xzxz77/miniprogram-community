<!-- pages/profile/subpages/my-posts/index.wxml -->
<view class="container bg-gray-50 min-h-screen p-4">
  <block wx:if="{{isLoading}}">
    <view class="text-center text-gray-400 py-10">加载中...</view>
  </block>
  <block wx:elif="{{postList.length === 0}}">
    <view class="text-center text-gray-400 py-20">
      <text>您还没有发布过动态</text>
    </view>
  </block>
  <block wx:else>
    <block wx:for="{{postList}}" wx:key="_id">
      <view class="bg-white rounded-xl p-4 shadow-sm mb-4" bindtap="onPostTap" data-id="{{item._id}}">
        <!-- Header with Date and Delete -->
        <view class="flex justify-between items-center mb-3">
          <view class="flex items-center">
             <view class="text-sm font-bold text-gray-900">{{item.author.nickName || '我'}}</view>
             <text class="text-xs text-gray-400 ml-2">{{item.timeAgo}}</text>
          </view>
          <view class="p-1" catchtap="onDeleteTap" data-id="{{item._id}}" data-index="{{index}}">
            <text class="iconfont icon-delete text-gray-400 text-sm">删除</text>
          </view>
        </view>

        <!-- Post Content -->
        <view class="text-gray-800 text-base mb-3 leading-relaxed">
          <text wx:if="{{item.category && item.category !== '全部'}}" class="text-blue-600 font-bold mr-1">#{{item.category}}#</text>
          {{item.content}}
        </view>

        <!-- Images Grid -->
        <view class="grid-3 gap-2 mb-3" wx:if="{{item.images && item.images.length > 0}}">
          <block wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" wx:for-index="imgIdx">
            <image class="post-img bg-gray-100" src="{{img}}" mode="aspectFill" catchtap="previewImage" data-urls="{{item.images}}" data-current="{{img}}"></image>
          </block>
        </view>

        <!-- Stats -->
        <view class="flex justify-between text-gray-500 text-sm pt-3 border-t border-gray-50">
          <view class="flex items-center">
            <text class="iconfont icon-comment mr-1"></text>
            <text>点赞{{item.commentCount || 0}}</text>
          </view>
          <view class="flex items-center">
            <text class="iconfont icon-thumb-up mr-1"></text>
            <text>收藏{{item.likeCount || 0}}</text>
          </view>
            <view class="flex items-center">
            <text class="iconfont icon-eye mr-1"></text>
            <text>浏览{{item.viewCount || 0}}</text>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>