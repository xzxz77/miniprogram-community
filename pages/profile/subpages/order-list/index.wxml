<!-- pages/profile/subpages/order-list/index.wxml -->
<view class="container">
  <!-- Tabs -->
  <view class="tabs bg-white sticky top-0 z-10">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="{{0}}">我买到的</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="{{1}}">我卖出的</view>
  </view>

  <!-- Order List -->
  <view class="order-list p-4">
    <block wx:if="{{isLoading}}">
       <view class="loading-state flex justify-center py-4">
         <text class="text-gray-400">加载中...</text>
       </view>
    </block>
    <block wx:elif="{{orderList.length === 0}}">
       <view class="empty-state flex flex-col items-center py-10">
         <image src="/assets/icons/empty.png" class="w-24 h-24 mb-2 opacity-50"></image>
         <text class="text-gray-400">暂无订单</text>
       </view>
    </block>
    <block wx:else>
      <block wx:for="{{orderList}}" wx:key="id">
        <view class="order-card bg-white rounded-xl p-4 shadow-sm mb-4" bindtap="onOrderTap" data-id="{{item.id}}">
          <!-- Header -->
          <view class="card-header flex justify-between items-center mb-3 pb-2 border-b border-gray-50">
            <view class="seller-info flex items-center">
              <image class="seller-avatar" src="{{item.sellerAvatar}}" mode="aspectFill"></image>
              <text class="seller-name">{{item.sellerName}}</text>
              <text class="iconfont icon-arrow-right text-gray-300 text-xs ml-1"></text>
            </view>
            <text class="status-text text-orange-500">{{item.statusText}}</text>
          </view>

          <!-- Content -->
          <view class="card-content flex mb-3">
            <image class="product-img bg-gray-100" src="{{item.productImage}}" mode="aspectFill"></image>
            <view class="product-info flex-1 flex flex-col justify-between ml-3">
              <text class="product-title line-clamp-2">{{item.productTitle}}</text>
              <view class="price-row flex justify-end items-baseline">
                <text class="price-label text-gray-500 mr-1">实付款</text>
                <text class="price-val">¥{{item.price}}</text>
              </view>
            </view>
          </view>

          <!-- Actions -->
          <view class="card-actions flex justify-end space-x-2 pt-1">
            <button class="action-btn outline" catchtap>联系对方</button>
            <button class="action-btn primary" wx:if="{{item.status === 'paid' && currentTab === 0}}">提醒发货</button>
            <button class="action-btn primary" wx:if="{{item.status === 'paid' && currentTab === 1}}">去发货</button>
          </view>
        </view>
      </block>
    </block>
  </view>
</view>
