/* pages/profile/subpages/order-list/index.wxss */
page {
  background-color: #f9fafb;
}

.bg-white { background-color: white; }
.p-4 { padding: 32rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.pb-2 { padding-bottom: 16rpx; }
.pt-1 { padding-top: 8rpx; }
.ml-1 { margin-left: 8rpx; }
.ml-3 { margin-left: 24rpx; }
.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.items-baseline { align-items: baseline; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }
.flex-1 { flex: 1; }

.tabs {
  display: flex;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
  position: sticky;
  top: 0;
}

.tab-item {
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #6b7280;
  position: relative;
}

.tab-item.active {
  color: #1f2937;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #f97316;
  border-radius: 4rpx;
}

.order-card {
  border-radius: 24rpx;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  border-bottom: 1rpx solid #f9fafb;
}

.seller-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.seller-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #374151;
}

.status-text {
  font-size: 28rpx;
  font-weight: 700;
}

.text-orange-500 { color: #f97316; }

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #f3f4f6;
}

.product-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.price-label {
  font-size: 24rpx;
}

.price-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.card-actions {
  display: flex;
}

.action-btn {
  margin: 0 0 0 16rpx;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 9999px;
  line-height: 1.5;
}

.action-btn.outline {
  background-color: white;
  color: #4b5563;
  border: 1rpx solid #d1d5db;
}

.action-btn.primary {
  background-color: #f97316;
  color: white;
  border: 1rpx solid #f97316;
}
