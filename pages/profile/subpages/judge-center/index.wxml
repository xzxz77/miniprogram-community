<!-- pages/profile/subpages/judge-center/index.wxml -->
<view class="container p-4">

  <block wx:if="{{isLoading}}">
    <view class="text-center text-gray-400 py-10">加载中...</view>
  </block>

  <block wx:elif="{{cases.length === 0}}">
    <view class="text-center text-gray-400 py-10">暂无待投票案件</view>
  </block>

  <block wx:else>
    <block wx:for="{{cases}}" wx:key="_id">
      <view class="case-card bg-white rounded-xl shadow-sm overflow-hidden mb-4" bindtap="onCaseTap" data-id="{{item._id}}">
        <view class="card-header bg-gray-800 text-white px-4 py-2 text-sm flex justify-between items-center">
          <text>案件 #{{item._id}}</text>
          <view class="status-badge bg-white-20 px-2 py-0.5 rounded text-xs">投票进行中</view>
        </view>
        <view class="p-4">
          <view class="flex justify-between items-start mb-3">
             <view class="case-title font-bold text-gray-800 flex-1 mr-2">{{item.reason}}</view>
             <view class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded">{{item.goodTitle}}</view>
          </view>
          
          <view class="claims flex space-x-4 mb-4">
            <view class="claim-box flex-1 bg-blue-50 p-3 rounded-lg">
              <view class="claim-label text-xs text-blue-500 mb-1 font-bold">买家主张</view>
              <view class="claim-text text-sm text-gray-800 line-clamp-3">{{item.description}}</view>
            </view>
            <view class="claim-box flex-1 bg-orange-50 p-3 rounded-lg">
              <view class="claim-label text-xs text-orange-500 mb-1 font-bold">卖家主张</view>
              <view class="claim-text text-sm text-gray-800 line-clamp-3">{{item.defendantResponse || '暂无申辩'}}</view>
            </view>
          </view>
          
          <view class="vote-actions">
            <button class="vote-btn w-full py-2 bg-blue-500 text-white rounded-lg font-bold text-sm shadow-md" catchtap="onCaseTap" data-id="{{item._id}}">
              {{item.hasVoted ? '查看详情' : '参与投票'}}
            </button>
          </view>
          <view class="vote-count text-center text-xs text-gray-400 mt-3">已有 {{item.voteCount}} 位邻居参与投票</view>
        </view>
      </view>
    </block>
  </block>
</view>