/* pages/profile/subpages/judge-center/index.wxss */
page {
  background-color: #f9fafb;
}

.p-4 { padding: 32rpx; }
.p-3 { padding: 24rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.px-2 { padding-left: 16rpx; padding-right: 16rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-1 { padding-top: 8rpx; padding-bottom: 8rpx; }
.py-10 { padding-top: 80rpx; padding-bottom: 80rpx; }

.mb-1 { margin-bottom: 8rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }

.bg-blue-50 { background-color: #eff6ff; }
.bg-orange-50 { background-color: #fff7ed; }
.text-blue-700 { color: #1d4ed8; }
.text-blue-500 { color: #3b82f6; }
.text-orange-500 { color: #f97316; }
.bg-blue-500 { background-color: #3b82f6; }

.bg-white { background-color: white; }
.bg-gray-800 { background-color: #1f2937; }
.bg-gray-100 { background-color: #f3f4f6; }
.bg-gray-50 { background-color: #f9fafb; }
.bg-white-20 { background-color: rgba(255, 255, 255, 0.2); }

.text-white { color: white; }
.text-gray-800 { color: #1f2937; }
.text-gray-500 { color: #6b7280; }
.text-gray-400 { color: #9ca3af; }

.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded { border-radius: 8rpx; }

.text-xs { font-size: 24rpx; }
.text-sm { font-size: 28rpx; }
.font-bold { font-weight: 700; }
.text-center { text-align: center; }

.flex { display: flex; }
.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

.space-x-4 > view + view { margin-left: 32rpx; }

.line-clamp-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.shadow-sm { box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05); }
.shadow-md { box-shadow: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1), 0 2rpx 4rpx -1rpx rgba(0, 0, 0, 0.06); }
