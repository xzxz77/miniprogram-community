/* pages/profile/subpages/collection-list/index.wxss */
page {
  background-color: #f9fafb;
}

.p-4 { padding: 32rpx; }

.grid-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.item-card {
  background-color: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.img-container {
  height: 320rpx;
  position: relative;
  background-color: #e5e7eb;
}

.item-img {
  width: 100%;
  height: 100%;
}

.status-tag {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  background-color: #3b82f6;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-tag.bg-gray {
  background-color: #9ca3af;
}

.p-3 { padding: 24rpx; }

.item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.flex { display: flex; }
.justify-between { justify-content: space-between; }
.items-end { align-items: flex-end; }
.mt-2 { margin-top: 16rpx; }

.price {
  color: #ef4444;
  font-weight: 700;
  font-size: 36rpx;
}

.currency {
  font-size: 24rpx;
}

.distance {
  font-size: 20rpx;
  color: #9ca3af;
}
