<!-- pages/profile/subpages/privacy-policy/index.wxml -->
<view class="container bg-white min-h-screen">
  <view class="px-6 py-8">
    <view class="text-center mb-8">
      <view class="text-xl font-bold text-gray-900 mb-2">{{title}}</view>
      <view class="text-xs text-gray-400">更新日期：{{updateDate}}</view>
    </view>
    
    <view class="content">
      <block wx:for="{{sections}}" wx:key="index">
        <view class="section mb-6">
          <view class="section-title text-base font-bold text-gray-800 mb-3">{{item.title}}</view>
          <block wx:for="{{item.content}}" wx:for-item="para" wx:key="*this">
             <view class="para text-sm text-gray-600 leading-relaxed mb-2">{{para}}</view>
          </block>
        </view>
      </block>
      
      <view class="footer text-center text-xs text-gray-400 mt-10 mb-6">
        <view>生效日期：{{effectiveDate}}</view>
        <view class="mt-1">© 2026 蜗牛集市小程序 版权所有</view>
      </view>
    </view>
  </view>
</view>