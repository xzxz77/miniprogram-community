/* pages/profile/index.wxss */
page {
  background-color: #f9fafb; /* bg-gray-50 */
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
}

.bg-white { background-color: #ffffff; }
.flex { display: flex; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.flex-1 { flex: 1; }
.relative { position: relative; }
.mt-1 { margin-top: 4rpx; }
.mt-2 { margin-top: 8rpx; }
.mt-4 { margin-top: 16rpx; }
.ml-4 { margin-left: 16rpx; }
.mb-4 { margin-bottom: 16rpx; }
.mb-6 { margin-bottom: 24rpx; }
.px-4 { padding-left: 16rpx; padding-right: 16rpx; }
.pb-4 { padding-bottom: 16rpx; }
.bg-blue-100 { background-color: #dbeafe; }
.text-blue-500 { color: #3b82f6; }
.bg-green-100 { background-color: #dcfce7; }
.text-green-500 { color: #22c55e; }
.bg-purple-100 { background-color: #f3e8ff; }
.text-purple-500 { color: #a855f7; }
.bg-gray-100 { background-color: #f3f4f6; }
.text-gray-500 { color: #6b7280; }
.text-gray-300 { color: #d1d5db; }


/* User Header */
.user-header {
  padding: 32rpx 24rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-container {
  width: 128rpx;
  height: 128rpx;
  position: relative;
}

.info-content {
  display: flex;
  flex-direction: column;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.1);
}

.verified-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background-color: #22c55e; /* green-500 */
  color: white;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 9999px;
  border: 2rpx solid #ffffff;
  display: flex;
  align-items: center;
}

.name {
  font-size: 36rpx; /* text-xl */
  font-weight: 700;
  color: #1f2937; /* gray-800 */
}

.edit-icon {
  color: #9ca3af; /* gray-400 */
  font-size: 28rpx;
  margin-left: 8rpx;
}

.location {
  font-size: 24rpx; /* text-xs */
  color: #6b7280; /* gray-500 */
}

.tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 9999px;
  margin-right: 8rpx;
}

.credit-tag {
  background-color: #fff7ed; /* orange-50 */
  color: #ea580c; /* orange-600 */
  border: 1rpx solid #ffedd5;
  font-weight: 700;
}

.time-tag {
  background-color: #f3f4f6; /* gray-100 */
  color: #6b7280; /* gray-500 */
}

/* Stats */
.stats-row {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1; /* Make items flexible */
  padding: 12rpx 1; /* Increase touch area */
}

.stat-num {
  font-size: 36rpx; /* text-lg */
  font-weight: 700;
  color: #1f2937;
}

.stat-label {
  font-size: 24rpx; /* text-xs */
  color: #6b7280;
}

/* Card Box */
.card-box {
  margin-left: 24rpx;
  margin-right: 24rpx;
  border-radius: 24rpx; /* rounded-xl */
  padding: 24rpx;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-weight: 700;
  color: #1f2937;
  font-size: 28rpx;
}

.more-link {
  font-size: 24rpx;
  color: #9ca3af;
  display: flex;
  align-items: center;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.icon-img {
  width: 56rpx; /* placeholder size */
  height: 56rpx;
  margin-bottom: 8rpx;
  background-color: #f3f4f6; /* placeholder bg */
  border-radius: 50%;
}

.icon-text {
  font-size: 24rpx;
  color: #4b5563; /* gray-600 */
}

.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #ef4444; /* red-500 */
  color: white;
  font-size: 20rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Menu List */
.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  padding: 32rpx;
  border-bottom: 1rpx solid #f9fafb;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151; /* gray-700 */
}

.menu-extra {
  font-size: 24rpx;
  color: #9ca3af;
  margin-right: 8rpx;
}

/* Invite Banner */
.invite-banner {
  background-color: #fff7ed;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invite-btn {
  margin: 0;
  font-size: 24rpx;
  background-color: #f97316;
  color: white;
  border-radius: 9999px;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* Edit Profile Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.modal-header {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 32rpx;
  color: #1f2937;
}

.form-item {
  margin-bottom: 24rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  padding: 0;
  background: none;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover; /* Ensure image covers the area without distortion */
}

.camera-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}

.label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  background: #f9fafb;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1f2937;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.btn {
  width: 260rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 9999px;
  margin: 0;
}

.btn.cancel {
  background: #f3f4f6;
  color: #4b5563;
}

.btn.save {
  background: #f97316;
  color: #ffffff;
}
