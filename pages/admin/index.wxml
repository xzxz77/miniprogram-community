<!-- pages/admin/index.wxml -->
<view class="container bg-gray-50 min-h-screen">
  <!-- Tabs -->
  <view class="flex bg-white border-b border-gray-100 sticky top-0 z-10">
    <block wx:for="{{tabs}}" wx:key="*this">
      <view class="flex-1 text-center py-3 text-sm font-bold {{activeTab === index ? 'text-blue-600 border-b-2 border-blue-600' : 'text-gray-500'}}" bindtap="onTabClick" data-index="{{index}}">
        {{item}}
      </view>
    </block>
  </view>

  <!-- Content -->
  <view class="p-4 pb-safe">
    <block wx:if="{{isLoading}}">
      <view class="text-center text-gray-400 py-10">加载中...</view>
    </block>
    
    <!-- Reports Tab -->
    <block wx:elif="{{activeTab === 0}}">
      <block wx:if="{{reports.length === 0}}">
        <view class="text-center text-gray-400 py-10">暂无待处理举报</view>
      </block>
      <block wx:else>
        <block wx:for="{{reports}}" wx:key="_id">
          <view class="bg-white rounded-xl p-4 shadow-sm mb-4">
            <view class="flex justify-between items-start mb-2">
              <view class="text-sm font-bold text-gray-800">举报原因: {{item.reason}}</view>
              <view class="text-xs text-gray-400">{{item.time}}</view>
            </view>
            <view class="text-sm text-gray-600 mb-2">商品: {{item.goodTitle}}</view>
            <view class="text-sm text-gray-600 mb-2">描述: {{item.description || '无'}}</view>
            
            <view class="grid grid-cols-3 gap-2 mb-3" wx:if="{{item.evidence && item.evidence.length > 0}}">
              <block wx:for="{{item.evidence}}" wx:key="*this" wx:for-item="img">
                <image class="w-full h-20 rounded bg-gray-100" src="{{img}}" mode="aspectFill" bindtap="previewImage" data-urls="{{item.evidence}}" data-current="{{img}}"></image>
              </block>
            </view>

            <view class="flex justify-end gap-2 border-t border-gray-50 pt-3">
              <button class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded" bindtap="handleReport" data-id="{{item._id}}" data-action="reject">忽略</button>
              <button class="bg-red-50 text-red-600 text-xs px-3 py-1 rounded" bindtap="handleReport" data-id="{{item._id}}" data-action="ban">违规下架</button>
              <button class="bg-blue-50 text-blue-600 text-xs px-3 py-1 rounded" bindtap="handleReport" data-id="{{item._id}}" data-action="process">已处理</button>
            </view>
          </view>
        </block>
      </block>
    </block>

    <!-- Audit Cases Tab (New) -->
    <block wx:elif="{{activeTab === 1}}">
      <block wx:if="{{auditCases.length === 0}}">
        <view class="text-center text-gray-400 py-10">暂无待审核案件</view>
      </block>
      <block wx:else>
        <block wx:for="{{auditCases}}" wx:key="_id">
          <view class="bg-white rounded-xl p-4 shadow-sm mb-4">
            <view class="flex justify-between items-start mb-2">
              <view class="text-sm font-bold text-gray-800">案件: {{item.reason}}</view>
              <view class="text-xs text-orange-500 font-bold">待审核</view>
            </view>
            <view class="text-sm text-gray-600 mb-2">商品: {{item.goodTitle}}</view>
            
            <view class="bg-blue-50 p-2 rounded mb-2">
              <view class="text-xs text-blue-500 font-bold mb-1">原告描述:</view>
              <view class="text-xs text-gray-700">{{item.description}}</view>
            </view>

            <view class="bg-orange-50 p-2 rounded mb-2">
              <view class="text-xs text-orange-500 font-bold mb-1">被告申辩:</view>
              <view class="text-xs text-gray-700">{{item.defendantResponse}}</view>
            </view>

            <view class="flex justify-end gap-2 border-t border-gray-50 pt-3">
              <button class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded" bindtap="handleCase" data-id="{{item._id}}" data-action="reject">驳回</button>
              <button class="bg-green-50 text-green-600 text-xs px-3 py-1 rounded" bindtap="handleCase" data-id="{{item._id}}" data-action="approve">通过审核</button>
            </view>
          </view>
        </block>
      </block>
    </block>

    <!-- Refund Audit Tab -->
    <block wx:elif="{{activeTab === 2}}">
      <block wx:if="{{refunds.length === 0}}">
        <view class="text-center text-gray-400 py-10">暂无待审核退款</view>
      </block>
      <block wx:else>
        <block wx:for="{{refunds}}" wx:key="_id">
          <view class="bg-white rounded-xl p-4 shadow-sm mb-4">
            <view class="flex justify-between items-start mb-2">
              <view class="text-sm font-bold text-gray-800">退款原因: {{item.reason}}</view>
              <view class="text-xs text-orange-500 font-bold">¥{{item.amount}}</view>
            </view>
            <view class="text-xs text-gray-400 mb-2">{{item.time}}</view>
            <view class="text-sm text-gray-600 mb-2">商品: {{item.goodTitle}}</view>
            <view class="text-sm text-gray-600 mb-2">说明: {{item.description || '无'}}</view>
            
            <view class="grid grid-cols-3 gap-2 mb-3" wx:if="{{item.evidence && item.evidence.length > 0}}">
              <block wx:for="{{item.evidence}}" wx:key="*this" wx:for-item="img">
                <image class="w-full h-20 rounded bg-gray-100" src="{{img}}" mode="aspectFill" bindtap="previewImage" data-urls="{{item.evidence}}" data-current="{{img}}"></image>
              </block>
            </view>

            <view class="flex justify-end gap-2 border-t border-gray-50 pt-3">
              <button class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded" bindtap="handleRefund" data-id="{{item._id}}" data-action="reject">拒绝退款</button>
              <button class="bg-green-50 text-green-600 text-xs px-3 py-1 rounded" bindtap="handleRefund" data-id="{{item._id}}" data-action="approve">同意退款</button>
            </view>
          </view>
        </block>
      </block>
    </block>

    <!-- Judge Cases Tab -->
    <block wx:elif="{{activeTab === 3}}">
      <block wx:if="{{cases.length === 0}}">
        <view class="text-center text-gray-400 py-10">暂无进行中案件</view>
      </block>
      <block wx:else>
        <block wx:for="{{cases}}" wx:key="_id">
          <view class="bg-white rounded-xl p-4 shadow-sm mb-4">
            <view class="flex justify-between items-start mb-2">
              <view class="text-sm font-bold text-gray-800">案件: {{item.reason}}</view>
              <view class="text-xs text-blue-500 font-bold">投票中</view>
            </view>
            <view class="text-sm text-gray-600 mb-2">商品: {{item.goodTitle}}</view>
            <view class="text-sm text-gray-600 mb-2">原告描述: {{item.description}}</view>
            
            <view class="flex justify-between items-center bg-gray-50 p-2 rounded mb-3">
              <view class="text-center flex-1 border-r border-gray-200">
                <view class="text-blue-500 font-bold">{{item.votes.support_plaintiff || 0}}</view>
                <view class="text-xs text-gray-400">支持原告</view>
              </view>
              <view class="text-center flex-1">
                <view class="text-orange-500 font-bold">{{item.votes.support_defendant || 0}}</view>
                <view class="text-xs text-gray-400">支持被告</view>
              </view>
            </view>

            <view class="flex justify-end gap-2 border-t border-gray-50 pt-3">
              <button class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded" bindtap="handleCase" data-id="{{item._id}}" data-action="reject">驳回案件</button>
              <button class="bg-blue-50 text-blue-600 text-xs px-3 py-1 rounded" bindtap="handleCase" data-id="{{item._id}}" data-action="resolve">强制结案</button>
            </view>
          </view>
        </block>
      </block>
    </block>
  </view>
</view>