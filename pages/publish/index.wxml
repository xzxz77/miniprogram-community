<!-- pages/publish/index.wxml -->
<view class="container bg-gray-50 flex-col h-100">
  <!-- Header -->
  <view class="header bg-white px-4 py-3 flex justify-between items-center sticky top-0 z-10">
    <text class="text-gray-600 text-lg" bindtap="onCancel">取消</text>
    <text class="font-bold text-lg text-black">发布闲置</text>
    <button class="publish-btn bg-orange-500 text-white px-6 py-1 rounded-full text-sm font-bold shadow-sm" bindtap="onPublish">发布</button>
  </view>

  <scroll-view scroll-y class="flex-1">
    <!-- Image Upload -->
    <view class="bg-white p-4 mb-2">
      <view class="flex flex-wrap gap-2">
        <view class="upload-btn w-24 h-24 bg-gray-50 rounded-lg flex-col items-center justify-center text-gray-400 border border-dashed border-gray-200" bindtap="onChooseImage">
          <text class="iconfont icon-camera text-2xl mb-1"></text>
          <text class="text-xs">添加图片</text>
        </view>
        <!-- Mock Uploaded Image -->
        <view class="w-24 h-24 relative rounded-lg overflow-hidden bg-gray-100">
          <image class="img-full" src="https://images.unsplash.com/photo-1546868871-7041f2a55e12?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&q=80" mode="aspectFill"></image>
          <view class="close-btn absolute top-1 right-1 bg-black-50 text-white rounded-full flex items-center justify-center" catchtap="onRemoveImage">
            <text class="iconfont icon-close text-xs font-bold"></text>
          </view>
        </view>
      </view>
      <view class="text-xs text-gray-400 mt-3 pl-1">长按图片可调整顺序，首张图片将作为封面</view>
    </view>

    <!-- Inputs -->
    <view class="bg-white px-4 mb-2">
      <view class="border-b border-gray-100 py-4">
        <input class="w-full text-lg font-bold placeholder-gray-400 text-gray-900" placeholder="标题 品牌型号都是买家喜欢搜索的" placeholder-class="placeholder-style" />
      </view>
      <view class="py-4 h-40">
        <textarea class="w-full h-full text-base placeholder-gray-400 text-gray-800" placeholder="描述一下宝贝的品牌型号、转手原因、新旧程度和入手渠道..." maxlength="-1" placeholder-class="placeholder-style"></textarea>
      </view>
    </view>

    <!-- Options -->
    <view class="bg-white mb-6">
      <!-- Location -->
      <view class="cell flex justify-between items-center px-4 py-4 border-b border-gray-50">
        <view class="flex items-center text-gray-700">
          <text class="iconfont icon-location w-6 text-gray-400 text-lg"></text>
          <text class="text-base">发货地</text>
        </view>
        <view class="flex items-center">
          <text class="text-base text-gray-900 font-bold mr-2">幸福花园小区</text>
          <text class="iconfont icon-arrow-right text-gray-300 text-sm"></text>
        </view>
      </view>
      
      <!-- Price -->
      <view class="cell flex justify-between items-center px-4 py-4 border-b border-gray-50">
        <view class="flex items-center text-gray-700">
          <text class="iconfont icon-tag w-6 text-gray-400 text-lg"></text>
          <text class="text-base">价格</text>
        </view>
        <view class="flex items-center text-red-500 font-bold">
          <text class="text-sm mr-1">¥</text>
          <input type="digit" value="1800" class="text-right text-xl w-24 font-din" />
        </view>
      </view>

      <!-- Category -->
      <view class="cell flex justify-between items-center px-4 py-4 border-b border-gray-50">
        <view class="flex items-center text-gray-700">
          <text class="iconfont icon-list w-6 text-gray-400 text-lg"></text>
          <text class="text-base">分类</text>
        </view>
        <view class="flex items-center">
          <text class="text-base text-gray-500 mr-2">数码产品</text>
          <text class="iconfont icon-arrow-right text-gray-300 text-sm"></text>
        </view>
      </view>

      <!-- Transaction Method -->
       <view class="cell flex justify-between items-center px-4 py-4">
        <view class="flex items-center text-gray-700">
          <text class="iconfont icon-truck w-6 text-gray-400 text-lg"></text>
          <text class="text-base">交易方式</text>
        </view>
        <view class="flex items-center">
          <text class="text-base text-gray-500 mr-2">自提/邮寄</text>
          <text class="iconfont icon-arrow-right text-gray-300 text-sm"></text>
        </view>
      </view>
    </view>

    <!-- Footer Agreement -->
    <view class="px-4 pb-8 flex items-center">
      <view class="checkbox mr-2 flex items-center justify-center rounded border border-orange-500 bg-orange-500" style="width: 32rpx; height: 32rpx;">
        <text class="iconfont icon-check text-white text-xs"></text>
      </view>
      <text class="text-xs text-gray-400">同意</text>
      <text class="text-xs text-blue-500 ml-1">《社区闲置交易规范》</text>
    </view>
  </scroll-view>
</view>
