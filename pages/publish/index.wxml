<!-- pages/publish/index.wxml -->
<view class="container">
  <scroll-view scroll-y class="content" enable-flex>
    <!-- Navigation Bar (Inside ScrollView) -->
    <view class="nav-bar">
      <view class="nav-right">
        <button class="publish-btn {{canPublish ? '' : 'disabled'}}" bindtap="onPublish" style="position: relative; left: 442rpx; top: 0rpx; width: 213rpx; display: block; box-sizing: border-box">发布</button>
      </view>
    </view>

    <!-- Main Content Card: Inputs & Images -->
    <view class="card input-card">
      <view class="input-group">
        <input class="title-input" placeholder="请输入商品标题" placeholder-class="placeholder" value="{{title}}" bindinput="onTitleInput" />
        
        <!-- Divider -->
        <view class="divider"></view>

        <textarea class="desc-input" placeholder="描述一下宝贝的品牌型号、转手原因、新旧程度和入手渠道..." placeholder-class="placeholder" maxlength="-1" value="{{description}}" bindinput="onDescInput" auto-height></textarea>
      </view>

      <!-- Image Grid -->
      <view class="media-grid">
        <block wx:for="{{images}}" wx:key="*this">
          <view class="media-item">
            <image src="{{item}}" mode="aspectFill" class="media-img" bindtap="previewImage" data-url="{{item}}"></image>
            <view class="delete-btn" catchtap="onRemoveImage" data-index="{{index}}">
              <text class="iconfont icon-close"></text>
            </view>
            <view wx:if="{{index === 0}}" class="cover-tag">封面</view>
          </view>
        </block>
        <!-- Limit to 5 images -->
        <view class="media-item add-btn" bindtap="onChooseImage" wx:if="{{images.length < 5}}">
          <text class="iconfont icon-camera"></text>
          <text class="add-text">{{images.length}}/5</text>
        </view>
      </view>
    </view>

    <!-- Settings Card -->
    <view class="card settings-card">
      <!-- Price -->
      <view class="setting-item">
        <view class="label">
          <text class="iconfont icon-rmb"></text>
          <text>价格</text>
        </view>
        <view class="value price-input-wrapper">
          <text class="currency">¥</text>
          <input type="digit" class="price-input" placeholder="0.00" value="{{price}}" bindinput="onPriceInput" />
        </view>
      </view>

      <!-- Category -->
      <picker range="{{categories}}" bindchange="onCategoryChange" value="{{categoryIndex}}">
        <view class="setting-item">
          <view class="label">
            <text class="iconfont icon-list"></text>
            <text>分类</text>
          </view>
          <view class="value">
            <text class="{{categoryIndex >= 0 ? 'text-dark' : 'text-placeholder'}}" style="height: 109rpx; display: block; box-sizing: border-box">
              {{categoryIndex >= 0 ? categories[categoryIndex] : '选择分类'}}
            </text>
            <text class="iconfont icon-arrow-right"></text>
          </view>
        </view>
      </picker>

      <!-- Location -->
      <view class="setting-item" bindtap="onLocationTap">
        <view class="label">
          <text class="iconfont icon-location"></text>
          <text>发货地</text>
        </view>
        <view class="value">
          <text class="text-dark">{{location}}</text>
          <text class="iconfont icon-arrow-right"></text>
        </view>
      </view>

      <!-- Delivery (Button Selection) -->
      <view class="setting-item column-layout no-border">
        <view class="label mb-2">
          <text class="iconfont icon-truck"></text>
          <text>交易方式</text>
        </view>
        <view class="tags-container">
          <view class="tag-btn {{deliveryIndex == index ? 'active' : ''}}" 
                wx:for="{{deliveryMethods}}" 
                wx:key="*this"
                bindtap="onDeliverySelect"
                data-index="{{index}}">
            {{item}}
          </view>
        </view>
      </view>
    </view>

    <!-- Agreement -->
    <view class="agreement" bindtap="onAgreeTap">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text class="iconfont icon-check" wx:if="{{agreed}}"></text>
      </view>
      <text class="text-gray">我已阅读并同意</text>
      <text class="link">《闲置交易规范》</text>
    </view>
  </scroll-view>
</view>