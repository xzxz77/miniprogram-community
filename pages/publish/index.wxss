/* pages/publish/index.wxss */
.h-100 { height: 100vh; }
.publish-btn { margin: 0; line-height: 1.5; font-size: 28rpx; }

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.aspect-square {
  position: relative;
  width: 100%;
  padding-bottom: 100%; /* Hack for aspect ratio */
  height: 0;
}

.upload-btn {
  border: 1rpx dashed #d1d5db;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100% !important; /* Override padding hack for flex container */
  padding-bottom: 0;
}

.img-full {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}

.close-btn {
  width: 40rpx; height: 40rpx;
  background: rgba(0,0,0,0.5);
}

.w-6 { width: 48rpx; text-align: center; margin-right: 16rpx; }
.w-20 { width: 160rpx; }
.h-32 { height: 256rpx; }

.cell:active { background-color: #f9fafb; }
.p-4 { padding: 32rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-4 { padding-top: 32rpx; padding-bottom: 32rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mt-2 { margin-top: 16rpx; }
.mr-2 { margin-right: 16rpx; }
