/* pages/publish/index.wxss */
page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* Navigation Bar */
.nav-bar {
  background-color: transparent; /* Changed from #fff to transparent */
  padding: 0 16rpx 24rpx 16rpx; /* Adjusted padding */
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* Removed sticky positioning and shadow */
  margin-bottom: 0;
}

.nav-left {
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 24rpx;
  background-color: #f0f2f5;
  border-radius: 32rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.nav-left:active {
  background-color: #e5e7eb;
  transform: scale(0.98);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.publish-btn {
  margin: 0;
  padding: 0 32rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: linear-gradient(135deg, #ff9a44 0%, #ff6b00 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 30rpx;
  border: none;
}

.publish-btn.disabled {
  background: #e5e5e5;
  color: #aaa;
}

/* Content Scroll */
.content {
  flex: 1;
  padding: 0 24rpx 24rpx; /* Removed top padding */
  box-sizing: border-box;
}

/* Cards */
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

/* Input Section */
.title-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  height: 80rpx;
  /* Removed border-bottom here, using divider instead */
  margin-bottom: 0; 
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 16rpx 0 24rpx 0;
}

.desc-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.placeholder {
  color: #ccc;
  font-weight: 400;
}

/* Media Grid */
.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.media-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%; /* Square aspect ratio */
  background-color: #f7f7f7;
  border-radius: 16rpx;
  overflow: hidden;
}

.media-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.delete-btn .iconfont {
  font-size: 20rpx;
  color: #fff;
}

.cover-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

.add-btn {
  border: 2rpx dashed #ddd;
  background-color: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 0; 
  padding-bottom: 100%; 
}

.add-btn .iconfont {
  position: absolute;
  top: 35%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
  color: #ccc;
}

.add-btn .add-text {
  position: absolute;
  top: 65%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  color: #999;
}

/* Settings List */
.settings-card {
  padding: 0 32rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 110rpx; /* min-height for flexible content */
  border-bottom: 1rpx solid #f5f5f5;
  padding: 20rpx 0; /* Add padding for multi-row items */
}

.setting-item.no-border {
  border-bottom: none;
}

.setting-item.column-layout {
  flex-direction: column;
  align-items: flex-start;
}

.label {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.label .iconfont {
  font-size: 36rpx;
  color: #333;
  margin-right: 20rpx;
}

.mb-2 {
  margin-bottom: 24rpx;
}

.value {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #999;
}

.text-dark {
  color: #333;
  font-weight: 500;
}

.text-placeholder {
  color: #ccc;
}

.value .iconfont {
  font-size: 24rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* Tags Container (Button Group) */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  width: 100%;
}

.tag-btn {
  padding: 12rpx 32rpx;
  background-color: #f5f6f8;
  color: #666;
  font-size: 26rpx;
  border-radius: 9999px;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-btn.active {
  background-color: #fff3e0;
  color: #ff6b00;
  border-color: #ff6b00;
  font-weight: 500;
}

/* Price Input */
.price-input-wrapper {
  color: #ff4d4f;
  font-weight: 700;
}

.currency {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.price-input {
  width: 160rpx;
  text-align: right;
  font-size: 40rpx;
  height: 60rpx;
  color: #ff4d4f;
}

/* Agreement */
.agreement {
  display: flex;
  align-items: center;
  padding: 0 16rpx 48rpx 16rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background-color: #ff6b00;
  border-color: #ff6b00;
}

.checkbox .iconfont {
  font-size: 20rpx;
  color: #fff;
}

.text-gray {
  font-size: 24rpx;
  color: #999;
}

.link {
  font-size: 24rpx;
  color: #576b95;
}
