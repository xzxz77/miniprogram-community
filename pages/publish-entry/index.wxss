/* pages/publish-entry/index.wxss */
page {
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
}

.container {
  min-height: 100vh;
  position: relative;
}

.close-btn {
  position: absolute;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 80rpx;
  background-color: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s;
}

.close-btn:active {
  transform: translateX(-50%) scale(0.9);
}

.selection-container {
  display: flex;
  justify-content: center;
}

.option-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  animation: slideUp 0.3s ease-out;
}

.option-card:nth-child(2) {
  animation-delay: 0.1s;
}

.icon-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
  transition: transform 0.1s;
}

.option-card:active .icon-circle {
  transform: scale(0.95);
}

.option-icon {
  width: 72rpx;
  height: 72rpx;
}

.option-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.bg-yellow-100 { background-color: #fef9c3; }
.bg-blue-100 { background-color: #dbeafe; }

.mb-20 { margin-bottom: 160rpx; }
.mb-10 { margin-bottom: 80rpx; }
.mr-8 { margin-right: 64rpx; }

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.pb-safe {
  padding-bottom: env(safe-area-inset-bottom);
}
