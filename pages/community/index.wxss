/* pages/community/index.wxss */
page {
  background-color: #f9fafb;
}

.min-h-screen {
  min-height: 100vh;
}

.sticky { position: sticky; }
.top-0 { top: 0; }
.z-10 { z-index: 10; }
.z-20 { z-index: 20; }

.bg-white { background-color: #ffffff; }
.bg-gray-50 { background-color: #f9fafb; }
.bg-gray-100 { background-color: #f3f4f6; }
.bg-gray-200 { background-color: #e5e7eb; }
.bg-orange-50 { background-color: #fff7ed; }

.text-gray-900 { color: #111827; }
.text-gray-800 { color: #1f2937; }
.text-gray-600 { color: #4b5563; }
.text-gray-500 { color: #6b7280; }
.text-gray-400 { color: #9ca3af; }
.text-gray-300 { color: #d1d5db; }
.text-orange-500 { color: #f97316; }
.text-orange-600 { color: #ea580c; }
.text-blue-500 { color: #3b82f6; }
.text-blue-600 { color: #2563eb; }
.text-white { color: #ffffff; }

.font-bold { font-weight: 700; }
.text-xs { font-size: 24rpx; }
.text-sm { font-size: 28rpx; }
.text-base { font-size: 30rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }

.rounded-full { border-radius: 9999px; }
.rounded { border-radius: 8rpx; }
.rounded-xl { border-radius: 24rpx; }

.border-b { border-bottom: 1rpx solid #f3f4f6; }
.border-t { border-top: 1rpx solid #f3f4f6; }
.border-l { border-left: 1rpx solid #f3f4f6; }
.border-r { border-right: 1rpx solid #f3f4f6; }
.border-orange-100 { border: 1rpx solid #ffedd5; }

.shadow-sm { box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05); }
.shadow-lg { box-shadow: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -2rpx rgba(0, 0, 0, 0.05); }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-1 { flex: 1; }

.p-4 { padding: 32rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.pb-2 { padding-bottom: 16rpx; }
.pt-3 { padding-top: 24rpx; }
.py-1 { padding-top: 12rpx; padding-bottom: 12rpx; }
.px-3 { padding-left: 24rpx; padding-right: 24rpx; }
.px-2 { padding-left: 16rpx; padding-right: 16rpx; }
.py- { padding-top: 4rpx; padding-bottom: 4rpx; }
.px-1 { padding-left: 8rpx; padding-right: 8rpx; }
.py-10 { padding-top: 80rpx; padding-bottom: 80rpx; }
.py-20 { padding-top: 160rpx; padding-bottom: 160rpx; }
.py-4 { padding-top: 32rpx; padding-bottom: 32rpx; }

.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }
.mr-6 { margin-right: 48rpx; }
.ml-3 { margin-left: 24rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mt-1 { margin-top: 4rpx; }
.gap-2 { gap: 16rpx; }

.relative { position: relative; }
.fixed { position: fixed; }
.bottom-24 { bottom: 192rpx; }
.right-4 { right: 32rpx; }

.w-12 { width: 96rpx; }
.h-12 { height: 96rpx; }
.w-24 { width: 192rpx; }
.h-24 { height: 192rpx; }

.opacity-50 { opacity: 0.5; }

.whitespace-nowrap { white-space: nowrap; }

.active-line {
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 8rpx;
  background: linear-gradient(to right, #f97316, #fb923c);
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(249, 115, 22, 0.3);
}

.tab-item.active {
  position: relative;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.post-img {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
}

.leading-relaxed {
  line-height: 1.6;
}

.transition-all {
  transition: all 0.3s;
}

.icon-img {
  width: 56rpx; /* placeholder size */
  height: 56rpx;
  margin-bottom: 8rpx;
  /* background-color: #f3f4f6; placeholder bg */
  border-radius: 50%;
}