<!-- pages/community/index.wxml -->
<top-notification id="top-notification"></top-notification>
<view class="container bg-gray-50 min-h-screen">
  <!-- Header -->
  <view class="header bg-white sticky top-0 z-10 border-b border-gray-100 pb-2">
    <!-- Status Bar Placeholder -->
    <!-- <view style="height: {{statusBarHeight}}px;"></view> -->
    
    <!-- Title Row -->
    <view class="flex justify-between items-center px-4 py-3">
      <view class="flex items-center">
        <text class="text-2xl font-bold text-gray-900 mr-2">邻里圈</text>
        <view class="bg-orange-50 text-orange-600 px-2 py-0.5 rounded-full text-xs font-bold flex items-center border border-orange-100">
          <text class="iconfont icon-location text-xs mr-1"></text>{{currentLocation}}
        </view>
      </view>
      <view class="bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full text-xs font-bold flex items-center">
        <text class="iconfont icon-bullhorn mr-1 text-orange-500"></text>小区公告
      </view>
    </view>

    <!-- Categories -->
    <scroll-view scroll-x class="whitespace-nowrap px-4" show-scrollbar="{{false}}">
      <view class="flex space-x-6 pb-2">
        <block wx:for="{{categories}}" wx:key="*this">
          <view class="tab-item {{currentCategory === item ? 'active' : ''}} mr-6 relative" bindtap="onCategoryTap" data-category="{{item}}">
            <text class="{{currentCategory === item ? 'text-lg font-bold text-gray-900' : 'text-base text-gray-500'}} transition-all">{{item}}</text>
            <view class="active-line" wx:if="{{currentCategory === item}}"></view>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- Content -->
  <view class="p-4">
    <block wx:if="{{isLoading && posts.length === 0}}">
      <view class="flex flex-col items-center justify-center py-20 min-h-[50vh]">
        <view class="text-gray-400 text-sm">加载中...</view>
      </view>
    </block>
    <block wx:elif="{{posts.length === 0}}">
       <view class="text-center text-gray-400 py-20 flex flex-col items-center">
         <!-- <image src="/assets/icons/empty.png" class="w-24 h-24 mb-2 opacity-50"></image> -->
         <text>这里静悄悄的，快来发布第一条动态吧~</text>
       </view>
    </block>
    <block wx:else>
      <block wx:for="{{posts}}" wx:key="_id">
        <view class="bg-white rounded-xl p-4 shadow-sm mb-4" bindtap="onPostTap" data-id="{{item._id}}">
          <!-- User Info -->
          <view class="flex justify-between items-start mb-3">
            <view class="flex items-center">
              <image class="avatar bg-gray-200" src="{{item.author.avatarUrl}}" mode="aspectFill"></image>
              <view class="ml-3">
                <view class="text-sm font-bold text-gray-900">{{item.author.nickName}}</view>
                <view class="flex items-center mt-0.5">
                   <text class="text-xs text-gray-400 mr-2">{{item.timeAgo}}</text>
                   <text class="text-xs text-gray-400 bg-gray-100 px-1 rounded">{{item.author.community}}</text>
                </view>
              </view>
            </view>
            <view class="p-1" catchtap>
              <text class="iconfont icon-more text-gray-400"></text>
            </view>
          </view>

          <!-- Post Content -->
          <view class="text-gray-800 text-base mb-3 leading-relaxed">
            <text wx:if="{{item.category && item.category !== '全部'}}" class="text-blue-600 font-bold mr-1">#{{item.category}}#</text>
            {{item.content}}
          </view>

          <!-- Images Grid -->
          <view class="grid-3 gap-2 mb-3" wx:if="{{item.images && item.images.length > 0}}">
            <block wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" wx:for-index="imgIdx">
              <image class="post-img bg-gray-100" src="{{img}}" mode="aspectFill" catchtap="previewImage" data-urls="{{item.images}}" data-current="{{img}}"></image>
            </block>
          </view>

          <!-- Actions -->
          <view class="flex justify-between text-gray-500 text-sm pt-3 border-t border-gray-50">
            <!-- <view class="flex items-center flex-1 justify-center" catchtap="onLikeTap" data-index="{{index}}">
              <text class="iconfont {{item.isLiked ? 'icon-thumb-up-fill text-orange-500' : 'icon-thumb-up'}} mr-1 text-lg"></text>
              <text>{{item.likeCount || '赞'}}</text>
            </view> -->
            <view class="flex items-center flex-1 justify-center border-l border-r border-gray-100">
              <text class="iconfont icon-comment mr-1 text-lg"></text>
              <text>评论</text>
            </view>
            <view class="flex items-center flex-1 justify-center">
              <text class="iconfont icon-share mr-1 text-lg"></text>
              <text>分享</text>
            </view>
          </view>
        </view>
      </block>
      
      <view wx:if="{{!hasMore}}" class="flex justify-center items-center text-gray-300 text-xs py-6">
        <text>没有更多了</text>
      </view>
    </block>
  </view>
  
  <!-- Floating Action Button -->
  <!-- <navigator url="/pages/publish-post/index" class="fixed bottom-24 right-4 bg-orange-500 text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg z-20 hover:opacity-90 transition-opacity">
    <image class="icon-img" src="/assets/icons/plus2.png" mode="aspectFit"></image>
  </navigator> -->
</view>