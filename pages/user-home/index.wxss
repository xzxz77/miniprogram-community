/* pages/user-home/index.wxss */
/* Utilities reusing existing styles */
.bg-gray-50 { background-color: #f9fafb; }
.bg-white { background-color: #ffffff; }
.bg-gray-100 { background-color: #f3f4f6; }
.bg-yellow-400 { background-color: #facc15; }
.bg-orange-500 { background-color: #ff6b00; }
.bg-gray-200 { background-color: #e5e7eb; }

.text-white { color: #fff; }
.text-gray-900 { color: #111827; }
.text-gray-800 { color: #1f2937; }
.text-gray-500 { color: #6b7280; }
.text-gray-400 { color: #9ca3af; }
.text-red-500 { color: #ef4444; }
.text-blue-600 { color: #2563eb; }

.font-bold { font-weight: 700; }
.text-xs { font-size: 24rpx; }
.text-sm { font-size: 28rpx; }
.text-base { font-size: 32rpx; }
.text-lg { font-size: 36rpx; }

.p-2 { padding: 16rpx; }
.p-4 { padding: 32rpx; }
.p-6 { padding: 48rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.px-6 { padding-left: 48rpx; padding-right: 48rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-10 { padding-top: 80rpx; padding-bottom: 80rpx; }
.pb-6 { padding-bottom: 48rpx; }
.pt-3 { padding-top: 24rpx; }
.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }
.ml-3 { margin-left: 24rpx; }
.m-0 { margin: 0; }

.w-20 { width: 160rpx; }
.h-20 { height: 160rpx; }
.w-full { width: 100%; }
.h-40 { height: 320rpx; }

.rounded-full { border-radius: 9999px; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded { border-radius: 8rpx; }
.shadow-sm { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-1 { flex: 1; }
.text-center { text-align: center; }
.space-x-3 > view + view, .space-x-3 > button + button { margin-left: 24rpx; }
.space-x-2 > view + view, .space-x-2 > image + image { margin-left: 16rpx; }

.grid-2-cols {
  column-count: 2;
  column-gap: 24rpx;
}

.break-inside {
  break-inside: avoid;
}

.block { display: block; }
.text-truncate {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.post-img {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background-color: #f3f4f6;
}

.border-t { border-top: 1rpx solid #f3f4f6; }
.border-l { border-left: 1rpx solid #f3f4f6; }
.border-r { border-right: 1rpx solid #f3f4f6; }

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.leading-relaxed {
  line-height: 1.6;
}
