<!-- pages/user-home/index.wxml -->
<view class="container bg-gray-50" style="min-height: 100vh;">
  <!-- Header Info -->
  <view class="bg-white p-6 mb-4 flex flex-col items-center">
    <image src="{{userInfo.avatarUrl}}" class="w-20 h-20 rounded-full mb-3 bg-gray-100" mode="aspectFill"></image>
    <view class="text-lg font-bold text-gray-900 mb-1">{{userInfo.nickName}}</view>
    <view class="text-sm text-gray-500 mb-4">{{userInfo.bio || '暂无签名'}}</view>
    <view class="flex space-x-3">
      <button class="bg-yellow-400 text-white font-bold text-sm px-6 py-2 rounded-full m-0" bindtap="onContact">私信</button>
      <button class="{{isFollowing ? 'bg-gray-200 text-gray-500' : 'bg-orange-500 text-white'}} font-bold text-sm px-6 py-2 rounded-full m-0" bindtap="onToggleFollow">
        {{isFollowing ? '已关注' : '关注'}}
      </button>
    </view>
  </view>

  <!-- Goods List -->
  <view class="px-4 pb-6">
    <view class="text-base font-bold text-gray-800 mb-3">在售宝贝 ({{goodsList.length}})</view>
    
    <view class="grid-2-cols">
      <block wx:for="{{goodsList}}" wx:key="_id">
        <navigator url="/pages/goods-detail/index?id={{item._id}}" class="bg-white rounded-lg overflow-hidden shadow-sm mb-3 break-inside">
           <image src="{{item.images[0]}}" mode="aspectFill" class="w-full h-40 bg-gray-100 block"></image>
           <view class="p-2">
             <view class="text-sm text-gray-900 text-truncate mb-1">{{item.title}}</view>
             <view class="text-red-500 font-bold text-sm">¥{{item.price}}</view>
           </view>
        </navigator>
      </block>
    </view>
    
    <view wx:if="{{goodsList.length === 0}}" class="text-center text-gray-400 py-10 text-sm">
      暂无在售商品
    </view>
  </view>

  <!-- Posts List -->
  <view class="px-4 pb-6">
    <view class="text-base font-bold text-gray-800 mb-3">发布的动态 ({{postsList.length}})</view>
    
    <block wx:for="{{postsList}}" wx:key="_id">
      <view class="bg-white rounded-xl p-4 shadow-sm mb-4" bindtap="onPostTap" data-id="{{item._id}}">
        <!-- User Info -->
        <view class="flex justify-between items-start mb-3">
          <view class="flex items-center">
            <image class="avatar bg-gray-200" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
            <view class="ml-3">
              <view class="text-sm font-bold text-gray-900">{{userInfo.nickName}}</view>
              <view class="flex items-center mt-0.5">
                 <text class="text-xs text-gray-400 mr-2">{{item.timeAgo}}</text>
                 <text class="text-xs text-gray-400 bg-gray-100 px-1 rounded">{{item.author.community || '幸福花园'}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- Post Content -->
        <view class="text-gray-800 text-base mb-3 leading-relaxed">
          <text wx:if="{{item.category && item.category !== '全部'}}" class="text-blue-600 font-bold mr-1">#{{item.category}}#</text>
          {{item.content}}
        </view>

        <!-- Images Grid -->
        <view class="grid-3 gap-2 mb-3" wx:if="{{item.images && item.images.length > 0}}">
          <block wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" wx:for-index="imgIdx">
            <image class="post-img bg-gray-100" src="{{img}}" mode="aspectFill" catchtap="previewImage" data-urls="{{item.images}}" data-current="{{img}}"></image>
          </block>
        </view>

        <!-- Actions -->
        <view class="flex justify-between text-gray-500 text-sm pt-3 border-t border-gray-50">
          <view class="flex items-center flex-1 justify-center">
            <text class="iconfont icon-thumb-up mr-1 text-lg"></text>
            <text>点赞{{item.likeCount || 0}}</text>
          </view>
          <view class="flex items-center flex-1 justify-center border-l border-r border-gray-100">
            <text class="iconfont icon-comment mr-1 text-lg"></text>
            <text>收藏{{item.commentCount || 0}}</text>
          </view>
          <view class="flex items-center flex-1 justify-center">
            <text class="iconfont icon-eye mr-1 text-lg"></text>
            <text>浏览{{item.viewCount || 0}}</text>
          </view>
        </view>
      </view>
    </block>
    
    <view wx:if="{{postsList.length === 0}}" class="text-center text-gray-400 py-10 text-sm">
      暂无动态
    </view>
  </view>
</view>