/* pages/home/subpages/category-detail/index.wxss */
page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  min-height: 100vh;
}

.search-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff6b00;
  padding-left: 24rpx;
  border-left: 2rpx solid #e5e7eb;
  margin-left: 16rpx;
}

/* Masonry Masonry */
.masonry {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.column {
  width: 48.5%;
  display: flex;
  flex-direction: column;
}

.goods-card {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.03);
  transition: transform 0.2s;
}

.goods-card:active {
  transform: scale(0.98);
}

.img-wrapper {
  position: relative;
}

.goods-img {
  width: 100%;
  display: block;
}

.tag-label {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-label.blue {
  background: rgba(33, 150, 243, 0.9);
}

.goods-info {
  padding: 20rpx;
}

.goods-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.price-group {
  display: flex;
  align-items: baseline;
  color: #ff4d4f;
}

.currency {
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 2rpx;
}

.amount {
  font-size: 36rpx;
  font-weight: 800;
  font-family: 'DIN Alternate', 'Roboto', sans-serif;
}

.seller-row {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f9fafb;
}

.seller-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.seller-name {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-ago {
  font-size: 20rpx;
  color: #bbb;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Utilities */
.flex { display: flex; }
.justify-between { justify-content: space-between; }
.items-center { align-items: center; }
.items-baseline { align-items: baseline; }
.pt-3 { padding-top: 24rpx; }
.pb-6 { padding-bottom: 48rpx; }
.px-3 { padding-left: 24rpx; padding-right: 24rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.text-center { text-align: center; }
.text-gray-300 { color: #d1d5db; }
.text-xs { font-size: 24rpx; }
.pb-safe { padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx); }

/* Search Bar */
.search-container {
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f5f6f8;
  border-radius: 9999px;
  height: 72rpx;
  padding: 0 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.text-gray-400 { color: #9ca3af; }
.text-lg { font-size: 32rpx; }
.mr-2 { margin-right: 16rpx; }
.bg-white { background-color: #fff; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
