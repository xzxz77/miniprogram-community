<!-- pages/home/index.wxml -->
<view class="container">
  <!-- Status Bar Spacer -->
  <view style="height: {{statusBarHeight}}px; background: #fff; width: 100%; position: fixed; top: 0; z-index: 100;"></view>

  <!-- Header (Fixed) -->
  <view class="header-container" style="top: {{statusBarHeight}}px;">
    <view class="flex justify-between items-center px-4 pt-2 pb-1 mt-2">
      <view class="flex items-center location-tag ">
        <text class="iconfont icon-location text-orange-600 mr-1 text-lg"></text>
        <text class="font-bold text-lg text-gray-900">幸福花园小区</text>
        <text class="iconfont icon-arrow-down text-xs ml-1 text-gray-400 font-bold"></text>
      </view>
      <view class="relative notification-box">
        <text class="iconfont icon-bell text-xl text-gray-800"></text>
        <view class="badge">3</view>
      </view>
    </view>
    
    <!-- Search Bar -->
    <view class="px-4 pb-2 pt-2" style="height: 124rpx; display: block; box-sizing: border-box">
      <view class="search-bar" style="position: relative; left: -3rpx; top: 17rpx">
        <text class="iconfont icon-search text-gray-400 mr-2 text-lg"></text>
        <input class="flex-1 text-sm text-gray-800" placeholder="搜索闲置好物..." placeholder-class="text-gray-400" />
        <view class="search-btn">搜索</view>
      </view>
    </view>
  </view>

  <!-- Scroll View (Content) -->
  <scroll-view scroll-y class="main-scroll" style="padding-top: {{statusBarHeight + 100}}px;">
    
    <!-- Categories -->
    <view class="category-panel mx-4 mt-3 bg-white rounded-2xl p-4 shadow-sm">
      <view class="grid-cols-5">
        <navigator url="/pages/home/subpages/category-detail/index?type=furniture" class="cat-item">
          <view class="cat-icon bg-orange-50"><image src="/assets/icons/furniture.png" class="cat-img"></image></view>
          <text class="cat-name">家具</text>
        </navigator>
        <view class="cat-item">
          <view class="cat-icon bg-blue-50"><image src="/assets/icons/digital.png" class="cat-img"></image></view>
          <text class="cat-name">数码</text>
        </view>
        <view class="cat-item">
          <view class="cat-icon bg-green-50"><image src="/assets/icons/clothes.png" class="cat-img"></image></view>
          <text class="cat-name">衣物</text>
        </view>
        <view class="cat-item">
          <view class="cat-icon bg-purple-50"><image src="/assets/icons/book.png" class="cat-img"></image></view>
          <text class="cat-name">图书</text>
        </view>
        <view class="cat-item">
          <view class="cat-icon bg-gray-50"><image src="/assets/icons/all.png" class="cat-img"></image></view>
          <text class="cat-name">全部分类</text>
        </view>
      </view>
    </view>

    <!-- Banner -->
    <view class="px-4 mt-4">
      <navigator url="/pages/home/subpages/neighborhood-market/index" class="banner-card">
        <view class="banner-content">
          <view class="banner-title">邻里集市</view>
          <view class="banner-desc">查看周边 3km 的好物</view>
        </view>
        <button class="banner-action-btn">立即查看</button>
        <!-- Decoration Circle -->
        <view class="decorative-circle"></view>
      </navigator>
    </view>

    <!-- Sticky Tabs (Inside ScrollView) -->
    <view class="sticky-tabs-container mt-6 px-4 mb-2">
      <view class="tab-item active">
        <text>最新发布</text>
        <view class="indicator"></view>
      </view>
      <view class="tab-item">
        <text>距离最近</text>
      </view>
      <view class="tab-item">
        <text>信用极好</text>
      </view>
    </view>

    <!-- Waterfall List -->
    <view class="masonry px-3 pb-6">
      <!-- Left Column -->
      <view class="column">
        <navigator url="/pages/goods-detail/index?id=1" class="goods-card">
          <view class="img-wrapper">
            <image class="goods-img" src="https://images.unsplash.com/photo-1546868871-7041f2a55e12?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" mode="widthFix"></image>
            <view class="tag-label">自提</view>
          </view>
          <view class="goods-info">
            <view class="goods-title">九成新 Apple Watch Series 7，几乎没用过</view>
            <view class="flex justify-between items-baseline mt-2">
              <view class="price-group">
                <text class="currency">¥</text>
                <text class="amount">1800</text>
              </view>
              <text class="original-price">¥3200</text>
            </view>
            <view class="seller-row mt-3">
              <image class="seller-avatar" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=50&h=50"></image>
              <text class="seller-name">李大爷</text>
              <view class="credit-badge">信用极好</view>
            </view>
          </view>
        </navigator>

        <view class="goods-card">
          <view class="img-wrapper">
            <image class="goods-img" src="https://images.unsplash.com/photo-1585336261022-680e295ce3fe?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" mode="widthFix"></image>
          </view>
          <view class="goods-info">
            <view class="goods-title">宜家置物架</view>
            <view class="flex justify-between items-baseline mt-2">
              <view class="price-group">
                <text class="currency">¥</text>
                <text class="amount">30</text>
              </view>
            </view>
            <view class="seller-row mt-3">
              <image class="seller-avatar" src="https://images.unsplash.com/photo-1527980965255-d3b416303d12?auto=format&fit=crop&w=50&h=50"></image>
              <text class="seller-name">张工</text>
            </view>
          </view>
        </view>
      </view>
      
      <!-- Right Column -->
      <view class="column">
        <view class="goods-card">
          <view class="img-wrapper">
            <image class="goods-img" src="https://images.unsplash.com/photo-1595341888016-a392ef81b7de?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" mode="widthFix"></image>
            <view class="tag-label blue">可邮寄</view>
          </view>
          <view class="goods-info">
            <view class="goods-title">儿童滑板车，闲置出，孩子长大了</view>
            <view class="flex justify-between items-baseline mt-2">
              <view class="price-group">
                <text class="currency">¥</text>
                <text class="amount">50</text>
              </view>
            </view>
            <view class="seller-row mt-3">
              <image class="seller-avatar" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=50&h=50"></image>
              <text class="seller-name">HappyMom</text>
              <text class="time-ago">10分钟前</text>
            </view>
          </view>
        </view>

         <view class="goods-card">
          <view class="img-wrapper">
            <image class="goods-img" src="https://images.unsplash.com/photo-1564466136-154737d6ec8c?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" mode="widthFix"></image>
          </view>
          <view class="goods-info">
            <view class="goods-title">全新未拆封拍立得相机</view>
            <view class="flex justify-between items-baseline mt-2">
              <view class="price-group">
                <text class="currency">¥</text>
                <text class="amount">350</text>
              </view>
            </view>
            <view class="seller-row mt-3">
              <image class="seller-avatar" src="https://images.unsplash.com/photo-1633332755192-727a05c4013d?auto=format&fit=crop&w=50&h=50"></image>
              <text class="seller-name">小王</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <view class="text-center text-gray-300 text-xs py-6 pb-safe">没有更多数据了</view>
  </scroll-view>
</view>
