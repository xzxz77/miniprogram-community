/* pages/pay/index.wxss */
page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* Card Common Styles */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  position: relative;
  overflow: hidden;
}

/* Address Card */
.address-card {
  padding-bottom: 40rpx; /* Space for bottom line */
}

.address-content {
  flex: 1;
}

.location-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tag {
  background: #ff6b00;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

.location {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
}

.detail-row {
  margin-bottom: 16rpx;
}

.detail {
  font-size: 28rpx;
  color: #4b5563;
}

.user-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6b7280;
}

.user-row .name {
  margin-right: 24rpx;
  font-weight: 500;
}

.arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #9ca3af;
  font-size: 32rpx;
}

.empty-address {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.icon-circle {
  width: 80rpx;
  height: 80rpx;
  background: #fff7ed;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.icon-circle .iconfont {
  color: #ff6b00;
  font-size: 40rpx;
}

.empty-address .tip {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.bottom-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: repeating-linear-gradient(
    45deg,
    #ff6b00,
    #ff6b00 20rpx,
    #fff 20rpx,
    #fff 40rpx,
    #3b82f6 40rpx,
    #3b82f6 60rpx,
    #fff 60rpx,
    #fff 80rpx
  );
}

/* Goods Card */
.shop-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #f3f4f6;
}

.shop-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.goods-content {
  display: flex;
}

.goods-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tags-row {
  margin-top: 8rpx;
}

.delivery-tag {
  font-size: 20rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  color: #ef4444;
}

.symbol {
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 2rpx;
}

.price {
  font-size: 36rpx;
  font-weight: 800;
  font-family: 'DIN Alternate', 'Roboto', sans-serif;
}

/* Options Card */
.options-card {
  padding: 0 32rpx;
}

.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
}

.border-b {
  border-bottom: 1rpx solid #f3f4f6;
}

.label {
  font-size: 28rpx;
  color: #374151;
}

.value {
  font-size: 28rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
}

.input {
  text-align: right;
  font-size: 28rpx;
  color: #1f2937;
  flex: 1;
  margin-left: 32rpx;
}

.placeholder {
  color: #9ca3af;
}

/* Bill Card */
.bill-card {
  padding-bottom: 24rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.row .label {
  color: #6b7280;
}

.row .value {
  color: #1f2937;
}

.row .value.highlight {
  color: #ef4444;
  font-weight: 500;
}

.divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 24rpx 0;
}

.total-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.total-row .label {
  font-size: 28rpx;
  color: #374151;
  margin-right: 12rpx;
}

.price-box {
  color: #ef4444;
  display: flex;
  align-items: baseline;
}

/* Bottom Bar */
.bottom-bar-placeholder {
  height: calc(110rpx + env(safe-area-inset-bottom));
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}

.price-container {
  display: flex;
  align-items: baseline;
}

.total-text {
  font-size: 28rpx;
  color: #374151;
  margin-right: 8rpx;
}

.pay-btn {
  background: linear-gradient(135deg, #ff9a44 0%, #ff6b00 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 20rpx 64rpx;
  border-radius: 9999px;
  margin: 0;
  line-height: 1.4;
  box-shadow: 0 8rpx 16rpx rgba(255, 107, 0, 0.2);
}

.pay-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
