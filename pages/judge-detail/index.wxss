/* pages/judge-detail/index.wxss */
.pb-safe {
  padding-bottom: env(safe-area-inset-bottom);
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* Grid Layout */
.grid {
  display: grid;
}

.grid-cols-3 {
  grid-template-columns: repeat(3, 1fr);
}

.gap-2 {
  gap: 16rpx;
}

.gap-4 {
  gap: 32rpx;
}

.mb-4 { margin-bottom: 32rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mr-2 { margin-right: 16rpx; }
.pb-3 { padding-bottom: 24rpx; }
.p-4 { padding: 32rpx; }
.p-3 { padding: 24rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-4 { padding-top: 32rpx; padding-bottom: 32rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.mt-4 { margin-top: 32rpx; }
.mt-1 { margin-top: 8rpx; }

/* Colors */
.text-blue-500 { color: #3b82f6; }
.text-blue-600 { color: #2563eb; }
.bg-blue-50 { background-color: #eff6ff; }
.bg-blue-500 { background-color: #3b82f6; }

.text-orange-600 { color: #ea580c; }

.border-b { border-bottom-width: 1rpx; }
.border-gray-50 { border-color: #f9fafb; }
.border-gray-200 { border-color: #e5e7eb; }
.border-r { border-right-width: 1rpx; }

.opacity-80 { opacity: 0.8; }
.flex-shrink-0 { flex-shrink: 0; }
.w-full { width: 100%; }
.h-full { height: 100%; }
.w-20 { width: 160rpx; }
.h-20 { height: 160rpx; }
.w-8 { width: 64rpx; }
.h-8 { height: 64rpx; }
.w-1 { width: 8rpx; }
.h-4 { height: 32rpx; }
.h-24 { height: 192rpx; }
.h-screen { height: 100vh; }

.last:border-0:last-child {
  border-bottom-width: 0;
}

.fixed { position: fixed; }
.bottom-0 { bottom: 0; }
.left-0 { left: 0; }
.z-50 { z-index: 50; }
.bg-gray-100 { background-color: #f3f4f6; }
.rounded-full { border-radius: 9999px; }
.border-t { border-top-width: 1rpx; }
.border-gray-100 { border-color: #f3f4f6; }
